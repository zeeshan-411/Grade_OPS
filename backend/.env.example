# Copy to backend/.env. Docker Compose loads it automatically.

# Database
POSTGRES_USER=gradeops
POSTGRES_PASSWORD=gradeops_dev_pw
POSTGRES_DB=gradeops
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT — generate a strong one for production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-prod-use-secrets-token_urlsafe-64
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — comma-separated origins for the React dev server, etc.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
